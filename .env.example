# ========================================
# base-nestjs — Environment variables
# ========================================

# ----- Server -----
PORT=3000
NODE_ENV=development
# Multi-origin: comma-separated. Default matches base-angular-admin dev server (:4200).
CORS_ORIGIN=http://localhost:4200

# ----- MongoDB -----
MONGODB_URI=mongodb://localhost:27017/app

# ----- Auth mode -----
# NONE    — skeleton mặc định, AuthGuard pass-through, không check auth
# JWT     — Bearer token (tương đương FE authMode='bearer', SPA/mobile)
# SESSION — session cookie + connect-mongo (tương đương FE authMode='cookie', web app có admin)
AUTH_MODE=NONE

# ----- Session (chỉ dùng khi AUTH_MODE=SESSION) -----
SESSION_SECRET=change-this-session-secret
SESSION_TTL_SECONDS=86400

# ----- JWT (chỉ dùng khi AUTH_MODE=JWT) -----
JWT_SECRET=change-this-jwt-secret
JWT_REFRESH_SECRET=change-this-jwt-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# S3-compatible storage (FREE tier)
# ========================================
#
# DEV: MinIO Docker local (docker-compose up -d)
#   Console: http://localhost:9001  (minioadmin/minioadmin)
#   Tạo bucket "my-media" lần đầu.
#
# PROD: Cloudflare R2 (10GB free, 0đ egress)
#   Chỉ cần đổi 3 dòng:
#     S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#     S3_ACCESS_KEY=<r2-access-key-id>
#     S3_SECRET_KEY=<r2-secret-access-key>
#     S3_REGION=auto
#     S3_FORCE_PATH_STYLE=false
#
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=my-media
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_EXPIRES=3600
